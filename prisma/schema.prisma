generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model persons {
  id           String      @id(map: "PK__persons__3213E83F2E6743A9") @unique(map: "UX_persons_id") @default(dbgenerated("newid()"), map: "DF__persons__id__49C3F6B7") @db.UniqueIdentifier
  first_name   String      @db.NVarChar(50)
  last_name    String      @db.NVarChar(50)
  phone_number String      @db.NVarChar(8)
  email        String      @db.NVarChar(75)
  created_at   DateTime    @default(now(), map: "DF__persons__created__4AB81AF0")
  updated_at   DateTime    @default(now(), map: "DF__persons__updated__4BAC3F29")
  deleted_at   DateTime?
  customers    customers[]
  users        users[]

  @@map("persons")
}

model categories {
  id          String     @id(map: "PK__categori__3213E83FEC177E98") @default(dbgenerated("newid()"), map: "DF__categories__id__5FB337D6") @db.UniqueIdentifier
  name        String     @db.NVarChar(50)
  description String?    @db.NVarChar(255)
  created_at  DateTime   @default(now(), map: "DF__categorie__creat__60A75C0F")
  updated_at  DateTime   @default(now(), map: "DF__categorie__updat__619B8048")
  deleted_at  DateTime?
  products    products[]
}

model products {
  id             String     @id(map: "PK__products__3213E83F4BB1566F") @default(dbgenerated("newid()"), map: "DF__products__id__6477ECF3") @db.UniqueIdentifier
  category_id    String     @db.UniqueIdentifier
  name           String     @db.NVarChar(50)
  description    String?    @db.NVarChar(255)
  sales_price    Decimal    @db.Decimal(18, 2)
  purchase_price Decimal    @db.Decimal(18, 2)
  created_at     DateTime   @default(now(), map: "DF__products__create__656C112C")
  updated_at     DateTime   @default(now(), map: "DF__products__update__66603565")
  deleted_at     DateTime?
  categories     categories @relation(fields: [category_id], references: [id], onUpdate: NoAction, map: "FK__products__catego__6754599E")
}

model rols {
  id          String    @id(map: "PK__rols__3213E83F75C532B6") @default(dbgenerated("newid()"), map: "DF__rols__id__4E88ABD4") @db.UniqueIdentifier
  rol_name    String    @db.NVarChar(50)
  description String?   @db.NVarChar(255)
  created_at  DateTime  @default(now(), map: "DF__rols__created_at__4F7CD00D")
  updated_at  DateTime  @default(now(), map: "DF__rols__updated_at__5070F446")
  deleted_at  DateTime?
  users       users[]
}

model users {
  id            String        @id(map: "PK__users__3213E83F461B4926") @default(dbgenerated("newid()"), map: "DF__users__id__534D60F1") @db.UniqueIdentifier
  person_id     String        @db.UniqueIdentifier
  username      String        @db.NVarChar(50)
  rol_id        String        @db.UniqueIdentifier
  password_hash String        @db.NVarChar(255)
  created_at    DateTime      @default(now(), map: "DF__users__created_a__5441852A")
  updated_at    DateTime      @default(now(), map: "DF__users__updated_a__5535A963")
  deleted_at    DateTime?
  bank_agents   bank_agents[]
  expenses      expenses[]
  persons       persons       @relation(fields: [person_id], references: [id], onUpdate: NoAction, map: "FK__users__person_id__5629CD9C")
  rols          rols          @relation(fields: [rol_id], references: [id], onUpdate: NoAction, map: "FK__users__rol_id__571DF1D5")
}

model account_types {
  id                String          @id(map: "PK__account___3213E83F3AF927D8") @default(dbgenerated("newid()"), map: "DF__account_type__id__29221CFB") @db.UniqueIdentifier
  account_type_name String          @unique(map: "idx_account_type_name") @db.NVarChar(75)
  created_at        DateTime?       @default(now(), map: "DF__account_t__creat__2A164134")
  updated_at        DateTime?
  deleted_at        DateTime?
  bank_accounts     bank_accounts[]
}

model banks {
  id            String          @id(map: "PK__banks__3213E83F0210ECE9") @default(dbgenerated("newid()"), map: "DF__banks__id__2CF2ADDF") @db.UniqueIdentifier
  bank_name     String          @db.NVarChar(75)
  description   String?         @db.NVarChar(255)
  created_at    DateTime?       @default(now(), map: "DF__banks__created_a__2DE6D218")
  updated_at    DateTime?
  deleted_at    DateTime?
  bank_accounts bank_accounts[]
  bank_agents   bank_agents[]
}

model bank_accounts {
  id              String        @id(map: "PK__bank_acc__3213E83F1A173CE6") @default(dbgenerated("newid()"), map: "DF__bank_account__id__31B762FC") @db.UniqueIdentifier
  initial_balance Decimal       @db.Decimal(18, 2)
  final_balance   Decimal       @db.Decimal(18, 2)
  bank_id         String        @db.UniqueIdentifier
  account_type_id String        @db.UniqueIdentifier
  account_number  String        @unique(map: "idx_bank_accounts_account_number") @db.NVarChar(50)
  created_at      DateTime?     @default(now(), map: "DF__bank_acco__creat__32AB8735")
  updated_at      DateTime?
  deleted_at      DateTime?
  account_name    String        @db.NVarChar(100)
  account_types   account_types @relation(fields: [account_type_id], references: [id], onUpdate: NoAction, map: "fk_bank_accounts_account_types")
  banks           banks         @relation(fields: [bank_id], references: [id], onUpdate: NoAction, map: "fk_bank_accounts_banks")
}

model customers {
  id          String        @id(map: "PK__costumer__3213E83FA35C6BF6") @default(dbgenerated("newid()"), map: "DF__costumers__id__59FA5E80") @db.UniqueIdentifier
  person_id   String        @db.UniqueIdentifier
  created_at  DateTime      @default(now(), map: "DF__costumers__creat__5AEE82B9")
  updated_at  DateTime      @default(now(), map: "DF__costumers__updat__5BE2A6F2")
  deleted_at  DateTime?
  bank_agents bank_agents[]
  persons     persons       @relation(fields: [person_id], references: [id], onUpdate: NoAction, map: "FK__costumers__perso__5CD6CB2B")
  expenses    expenses[]
}

model expenses {
  id           String    @id(map: "PK__expenses__3213E83F8069AABF") @default(dbgenerated("newid()"), map: "DF__expenses__id__46B27FE2") @db.UniqueIdentifier
  description  String    @db.NVarChar(255)
  customer_id  String    @db.UniqueIdentifier
  user_id      String    @db.UniqueIdentifier
  amount       Decimal   @db.Decimal(18, 2)
  created_at   DateTime  @default(dbgenerated("sysdatetime()"), map: "DF__expenses__create__47A6A41B")
  updated_at   DateTime  @default(dbgenerated("sysdatetime()"), map: "DF__expenses__update__489AC854")
  deleted_at   DateTime?
  expense_type String?   @db.NVarChar(50)
  customers    customers @relation(fields: [customer_id], references: [id], onUpdate: NoAction, map: "FK_expenses_customers")
  users        users     @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "FK_expenses_users")
}

model bank_agents {
  id           String    @id(map: "PK__bank_age__3213E83F21B7006E") @default(dbgenerated("newid()"), map: "DF__bank_agents__id__625A9A57") @db.UniqueIdentifier
  customer_id  String    @db.UniqueIdentifier
  bank_id      String    @db.UniqueIdentifier
  description  String    @db.NVarChar(255)
  amount       Decimal   @db.Decimal(18, 2)
  payment_date DateTime  @db.Date
  user_id      String    @db.UniqueIdentifier
  created_at   DateTime  @default(dbgenerated("sysdatetime()"), map: "DF__bank_agen__creat__634EBE90")
  updated_at   DateTime  @default(dbgenerated("sysdatetime()"), map: "DF__bank_agen__updat__6442E2C9")
  deleted_at   DateTime?
  banks        banks     @relation(fields: [bank_id], references: [id], onUpdate: NoAction, map: "FK_bank_agents_bank")
  customers    customers @relation(fields: [customer_id], references: [id], onUpdate: NoAction, map: "FK_bank_agents_customer")
  users        users     @relation(fields: [user_id], references: [id], onUpdate: NoAction, map: "FK_bank_agents_user")
}
