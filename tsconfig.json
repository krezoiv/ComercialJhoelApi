{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2022",

    "rootDir": "./src",
    "outDir": "./dist",
      "baseUrl": "./",   
      "paths": {
      "src/*": ["src/*"]
    },
  

    "esModuleInterop": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,

    "strict": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules", "dist", "test"]
}